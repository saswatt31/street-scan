# StreetScan Environment Configuration
# Copy this file to .env.local and populate with your own keys.
# ──────────────────────────────────────────────────────────────

# 1. Supabase (Required)
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-DO-NOT-EXPOSE

# 2. AI Services (Required for Image/IoT Analysis)
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-gemini-api-key

# URL for the local YOLO Python service
# Default: http://localhost:8000
NEXT_PUBLIC_YOLO_SERVICE_URL=http://localhost:8000
YOLO_API_KEY=dev-yolo-secret

# 3. Security & Background Jobs
# Protects the /api/jobs/run endpoint. Match this with your cron/worker config.
CRON_SECRET=dev-secret-key

# 4. App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 5. Optional Integrations (Stubs implemented)
# RESEND_API_KEY=re_...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=...
