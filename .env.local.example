# ──────────────────────────────────────────────
# StreetScan Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Background job cron protection
# Set to any secret string; pass as X-Cron-Secret header when calling /api/jobs/run
CRON_SECRET=change-me-in-production

# AI image analysis (optional — mock runs without this)
# ANTHROPIC_API_KEY=sk-ant-...

# Email (optional — stub logs to console without this)
# RESEND_API_KEY=re_...

# SMS (optional — stub logs to console without this)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...
